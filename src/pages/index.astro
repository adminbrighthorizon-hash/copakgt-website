---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${site.name} | ${site.tagline}`} description={site.subheadline}>
	<SiteShell activePath="/">
		<main>
			<section class="hero section">
				<div class="hero-panel panel" style={`--hero-image: url('${site.heroImage}')`}>
					<div class="hero-backdrop" aria-hidden="true"></div>
					<div class="hero-copy">
						<h1>{site.tagline}</h1>
						<p>{site.subheadline}</p>
						<div class="hero-actions">
							<a class="btn btn-primary" href="#services">Explore Products & Services</a>
							<a class="btn btn-ghost" href={`${base}/contact`}>Talk to Our Team</a>
						</div>
					</div>
				</div>
			</section>

			<section class="section section-gap">
				<div class="grid two">
					<article class="panel block">
						<h2>Company Overview</h2>
						<p>
							COPAK GENERAL TRADING (CGT) is a leading Congolese company recognized for complete industrial
							solutions across supply, installation, and maintenance. We support Electrical, Mechanical,
							Instrumentation, Electrowinning, Screen Panels, Drilling Safety Gaskets, Motors, Gearboxes,
							Mechanical Seals, Equipment Spares, Pumps, Valves, Reagents, Chemicals, Laboratory Equipment,
							PPE, and Conveyor Belt systems.
						</p>
					</article>
					<article class="panel block">
						<h2>Our Commitments</h2>
						<ul>
							{site.commitments.map((item) => <li>{item}</li>)}
						</ul>
					</article>
				</div>
			</section>

			<section id="services" class="section section-gap">
				<div class="section-head">
					<p class="eyebrow">Products & Services</p>
					<h2>Industrial Expertise Across Key Operational Domains</h2>
				</div>
				<div class="service-grid">
					{site.serviceCards.map((card) => (
						<article class="service-card panel">
							<div class={`service-media${card.images.length > 1 ? ' service-media--duo' : ''}`}>
								{card.images.map((src, i) => (
									<img src={src} alt={i === 0 ? card.title : `${card.title} ${i + 1}`} loading="lazy" decoding="async" />
								))}
							</div>
							<div class="service-copy">
								<h3>{card.title}</h3>
								<p>{card.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="section section-gap">
				<div class="grid two">
					<article class="panel block">
						<h2>Vision</h2>
						<p>{site.vision}</p>
					</article>
					<article class="panel block">
						<h2>Mission</h2>
						<p>{site.mission}</p>
					</article>
				</div>
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.hero {
		padding-top: 2rem;
	}

	.hero-panel {
		position: relative;
		overflow: hidden;
		min-height: 480px;
	}

	.hero-backdrop {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(10, 12, 14, 0.92) 0%, rgba(10, 12, 14, 0.72) 42%, rgba(10, 12, 14, 0.4) 100%),
			var(--hero-image) center/cover no-repeat;
		filter: saturate(1.05) contrast(1.04);
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		padding: clamp(1.4rem, 4vw, 3rem);
		max-width: 760px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: 480px;
	}

	.hero-copy h1 {
		font-size: clamp(1.9rem, 4vw, 3.2rem);
		margin: 0.4rem 0 0.8rem;
		color: #fff;
	}

	.hero-copy p {
		color: #efe7dd;
		max-width: 64ch;
	}

	.hero-actions {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.2rem;
		flex-wrap: wrap;
	}

	.section-gap {
		padding: 2rem 0;
	}

	.section-head {
		margin-bottom: 1rem;
	}

	.section-head h2 {
		font-size: clamp(1.5rem, 2.7vw, 2.2rem);
	}

	.grid.two {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.block {
		padding: 1.2rem;
	}

	.block h2 {
		margin-bottom: 0.7rem;
	}

	.block p,
	.block li {
		color: var(--muted);
	}

	.block ul {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.45rem;
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.service-card {
		overflow: hidden;
		transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
	}

	.service-card:hover {
		transform: translateY(-4px);
		border-color: rgba(255, 106, 0, 0.45);
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.24);
	}

	.service-media {
		display: grid;
		grid-template-columns: 1fr;
	}

	.service-media--duo {
		grid-template-columns: 1fr 1fr;
	}

	.service-media img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		display: block;
		filter: saturate(1.06) contrast(1.02);
	}

	.service-media--duo img {
		height: 220px;
	}

	.service-copy {
		padding: 0.9rem;
	}

	.service-copy h3 {
		margin-bottom: 0.4rem;
		font-size: 1.1rem;
	}

	.service-copy p {
		margin: 0;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 0.62rem 0.96rem;
		border-radius: 0.65rem;
		font-size: 0.82rem;
		font-weight: 600;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 10px 24px rgba(255, 106, 0, 0.18);
	}

	.btn-primary {
		background: linear-gradient(135deg, #d95400, #e77c1f);
		color: #fff;
		border: 1px solid rgba(224, 109, 28, 0.56);
	}

	.btn-ghost {
		border: 1px solid rgba(224, 109, 28, 0.62);
		background: rgba(217, 84, 0, 0.23);
		color: #fff;
	}

	@media (max-width: 980px) {
		.grid.two {
			grid-template-columns: 1fr;
		}

		.service-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.service-grid {
			grid-template-columns: 1fr;
		}
	}
</style>