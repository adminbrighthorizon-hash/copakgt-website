---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const contactBackground = `${base}/photos/company-profile/contact-bg.jpg`;
---

<Layout title={`Contact | ${site.name}`} description="Contact COPAK GENERAL TRADING for industrial products and service enquiries.">
	<SiteShell activePath="/contact">
		<main class="section contact-page">
			<section class="panel intro" style={`--contact-bg: url('${contactBackground}')`}>
				<p class="eyebrow">Contact</p>
				<h1>Let’s Discuss Your Industrial Requirements</h1>
				<p>Reach our team for quotations, technical consultations, and partnership opportunities.</p>
			</section>

			<section class="grid two section-gap">
				<article class="panel block">
					<h2>Direct Contact</h2>
					<p>Email: <a href={`mailto:${site.contacts.email}`}>{site.contacts.email}</a></p>
					{site.contacts.phones.map((phone) => (
						<p>Phone: <a href={`tel:${phone.replace(/\s+/g, '')}`}>{phone}</a></p>
					))}
					<p>Website: <a href={site.contacts.website} target="_blank" rel="noreferrer">{site.contacts.website}</a></p>
				</article>
				<article class="panel block">
					<h2>Office Address</h2>
					<p>{site.contacts.address}</p>
				</article>
			</section>

			<section class="section-gap panel block">
				<h2>Send Us a Message</h2>
				<p class="form-note">Complete the form below and we will send your message to brighthorizonza@gmail.com (testing).</p>
				<form id="contact-form" class="contact-form">
					<div class="contact-form-grid">
						<label>
							<span>Full Name</span>
							<input type="text" name="name" autocomplete="name" required />
						</label>
						<label>
							<span>Email Address</span>
							<input type="email" name="email" autocomplete="email" required />
						</label>
						<label>
							<span>Phone Number</span>
							<input type="tel" name="phone" autocomplete="tel" />
						</label>
						<label>
							<span>Subject</span>
							<input type="text" name="subject" required />
						</label>
					</div>
					<label class="honeypot" aria-hidden="true">
						<span>Leave this field empty</span>
						<input type="text" name="company" tabindex="-1" autocomplete="off" />
					</label>
					<label>
						<span>Message</span>
						<textarea name="message" rows="6" required></textarea>
					</label>
					<button class="form-submit" type="submit">Send Email</button>
					<p id="form-status" class="form-status" role="status" aria-live="polite"></p>
				</form>
			</section>

			<section class="section-gap panel block legal">
				<h2>Business Registration</h2>
				<div class="legal-grid">
					<p><strong>RCCM:</strong> {site.contacts.rccm}</p>
					<p><strong>ID NAT:</strong> {site.contacts.idNat}</p>
					<p><strong>Tax Number:</strong> {site.contacts.taxNumber}</p>
					<p><strong>ARSP:</strong> {site.contacts.arsp}</p>
				</div>
			</section>
		</main>
	</SiteShell>
</Layout>

<script>
	// Replace the value below with your Web3Forms access key.
	// For testing, create the key using brighthorizonza@gmail.com at https://web3forms.com.
	const WEB3FORMS_ACCESS_KEY = '473d2d77-7c29-493c-86b6-2153e254275d';

	const contactForm = document.getElementById('contact-form');
	const formStatus = document.getElementById('form-status');

	if (contactForm instanceof HTMLFormElement && formStatus instanceof HTMLParagraphElement) {
		contactForm.addEventListener('submit', (event) => {
			event.preventDefault();
			const formData = new FormData(contactForm);

			const name = (formData.get('name') ?? '').toString().trim();
			const email = (formData.get('email') ?? '').toString().trim();
			const phone = (formData.get('phone') ?? '').toString().trim();
			const subject = (formData.get('subject') ?? '').toString().trim();
			const message = (formData.get('message') ?? '').toString().trim();
			const company = (formData.get('company') ?? '').toString().trim();

			if (!name || !email || !subject || !message) {
				formStatus.textContent = 'Please complete all required fields.';
				formStatus.dataset.state = 'error';
				return;
			}

			// Honeypot spam check
			if (company) {
				formStatus.textContent = 'Message sent successfully. We will contact you soon.';
				formStatus.dataset.state = 'success';
				contactForm.reset();
				return;
			}

			formStatus.textContent = 'Sending...';
			formStatus.dataset.state = 'pending';
			const submitButton = contactForm.querySelector('button[type="submit"]');
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
			}

			const body = [
				`Phone: ${phone || 'N/A'}`,
				'',
				'Message:',
				message,
			].join('\n');

			// Free plan payload: access_key routes to the primary inbox for this key.
			fetch('https://api.web3forms.com/submit', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					access_key: WEB3FORMS_ACCESS_KEY,
					from_name: 'COPAK Website',
					name,
					email,
					subject: `[COPAK Website] ${subject}`,
					message: body,
				}),
			})
				.then(async (response) => {
					const payload = await response.json().catch(() => ({}));
					if (payload?.success) {
						formStatus.textContent = 'Message sent successfully. We will contact you soon.';
						formStatus.dataset.state = 'success';
						contactForm.reset();
					} else {
						throw new Error(payload?.message || 'Unable to send message right now.');
					}
				})
				.catch((error) => {
					formStatus.textContent =
						error instanceof Error
							? error.message
							: 'Unable to send message right now. Please try again or email us directly.';
					formStatus.dataset.state = 'error';
				})
				.finally(() => {
					if (submitButton instanceof HTMLButtonElement) {
						submitButton.disabled = false;
					}
				});
		});
	}
</script>

<style>
	.contact-page {
		padding: 2rem 0;
	}

	.intro,
	.block {
		padding: 1.2rem;
	}

	.intro {
		position: relative;
		overflow: hidden;
	}

	.intro::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(100deg, rgba(15, 17, 19, 0.9) 0%, rgba(15, 17, 19, 0.74) 48%, rgba(15, 17, 19, 0.88) 100%),
			var(--contact-bg) center/cover no-repeat;
		opacity: 0.93;
		z-index: 0;
		animation: introPan 18s ease-in-out infinite alternate;
		transform-origin: center;
	}

	.intro > * {
		position: relative;
		z-index: 1;
	}

	@keyframes introPan {
		0% {
			transform: scale(1.05) translate3d(0, 0, 0);
		}
		100% {
			transform: scale(1.11) translate3d(-2%, -1%, 0);
		}
	}

	.intro h1 {
		font-size: clamp(1.8rem, 3.8vw, 2.7rem);
		margin: 0.4rem 0 0.8rem;
	}

	.intro p,
	.block p {
		color: var(--muted);
	}

	.block a {
		color: var(--text);
	}

	.form-note {
		margin: 0.5rem 0 0.9rem;
	}

	.contact-form {
		display: grid;
		gap: 0.85rem;
	}

	.contact-form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75rem;
	}

	.contact-form label {
		display: grid;
		gap: 0.35rem;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.contact-form span {
		font-size: 0.9rem;
		color: var(--muted);
	}

	.contact-form input,
	.contact-form textarea {
		width: 100%;
		background: #12161a;
		border: 1px solid var(--border);
		color: var(--text);
		border-radius: 0.55rem;
		padding: 0.72rem 0.8rem;
		font: inherit;
	}

	.contact-form input:focus,
	.contact-form textarea:focus {
		outline: 2px solid rgba(226, 90, 0, 0.35);
		outline-offset: 1px;
		border-color: var(--accent);
	}

	.form-submit {
		width: fit-content;
		border: 1px solid transparent;
		background: var(--accent);
		color: #fff;
		padding: 0.7rem 1.15rem;
		border-radius: 0.55rem;
		font-weight: 600;
		cursor: pointer;
		transition: filter 0.2s ease;
	}

	.form-submit:hover {
		filter: brightness(1.06);
	}

	.form-submit:disabled {
		opacity: 0.7;
		cursor: wait;
	}

	.form-status {
		margin: 0;
		font-size: 0.92rem;
		color: var(--muted);
	}

	.form-status[data-state='success'] {
		color: #66d99c;
	}

	.form-status[data-state='error'] {
		color: #ff8b8b;
	}

	.grid.two {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.section-gap {
		padding-top: 1rem;
	}

	.legal-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
	}

	@media (max-width: 980px) {
		.grid.two,
		.contact-form-grid,
		.legal-grid {
			grid-template-columns: 1fr;
		}
	}
</style>