---

<Layout title="Services — COPAK General Trading" description="COPAK General Trading provides electrical, mechanical, instrumentation, conveyor, PPE, lab equipment, pumps, valves, and more across the DRC.">

  <!-- PAGE HERO -->
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1920&h=900&q=80"
        alt=""
        class="w-full h-full object-cover"
        style="animation: subtle-zoom 24s ease-in-out infinite alternate;"
        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&w=1920&h=900&q=80';"
      />
      <div class="absolute inset-0 bg-[#0d1b2a]/78"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2a]/88 via-[#1a2838]/55 to-[#0d1b2a]/72"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">
      <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">What We Offer</p>
      <h1 class="text-5xl lg:text-6xl font-['Rajdhani'] font-bold text-white mb-6 leading-tight">
        Products &amp; <span class="text-orange-400">Services</span>
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl leading-relaxed">
        A comprehensive range of industrial equipment and specialized services — from supply and installation to maintenance and technical support — across 12+ service categories.
      </p>
    </div>
  </section>

  <!-- SERVICE OVERVIEW STATS -->
  <section class="bg-[#2a4563] border-y border-orange-500/15 py-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
      {[
        { value: '12+', label: 'Service Categories' },
        { value: '60+', label: 'Product Lines' },
        { value: '100%', label: 'Quality Assured' },
        { value: '24/7', label: 'Technical Support' },
      ].map(s => (
        <div>
          <p class="text-3xl font-['Rajdhani'] font-bold text-orange-400">{s.value}</p>
          <p class="text-gray-400 text-xs tracking-widest uppercase mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICE CARDS -->
  <section class="py-20 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">
      {services.map(s => (
        <div class={`group bg-[#35546d] border rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col ${s.color === 'blue' ? 'border-blue-400/20 hover:border-blue-400/35' : 'border-orange-400/20 hover:border-orange-400/35'}`}>
          <!-- Service Image -->
          <div class="relative h-44 overflow-hidden bg-gradient-to-br from-[#4b6a83] to-[#274056]">
            <img 
              src={s.image}
              alt={s.title}
              loading="lazy"
              onerror="this.src='https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&w=900&h=600&q=80'"
              class="w-full h-full object-cover opacity-100 group-hover:scale-105 transition-all duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1f3447]/35 via-transparent to-transparent pointer-events-none"></div>
            <div class="absolute top-3 right-3 text-[11px] px-2 py-1 rounded-full bg-black/35 text-white/90 border border-white/20 backdrop-blur-sm">CGT</div>
          </div>
          
          <!-- Service Content -->
          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center gap-4 mb-4">
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl ${s.color === 'blue' ? 'bg-blue-600/20' : 'bg-orange-500/20'}`}>
                {s.icon}
              </div>
              <h3 class="text-white font-['Rajdhani'] font-bold text-xl leading-tight">{s.title}</h3>
            </div>
            <p class="text-gray-300 text-sm leading-relaxed mb-5">{s.desc}</p>
            <ul class="mt-auto space-y-1.5">
              {s.items.slice(0, 5).map(item => (
                <li class="flex items-start gap-2 text-sm text-gray-300">
                  <span class={`mt-1.5 w-1.5 h-1.5 rounded-full shrink-0 ${s.color === 'blue' ? 'bg-blue-500' : 'bg-orange-500'}`}></span>
                  {item}
                </li>
              ))}
              {s.items.length > 5 && (
                <li class="text-xs text-gray-500 italic pt-2 pl-3">+{s.items.length - 5} more items</li>
              )}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#2a4563] border-t border-orange-500/15">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-['Rajdhani'] font-bold text-white mb-4">Need a Specific Solution?</h2>
      <p class="text-gray-300 mb-8 leading-relaxed">
        CGT provides customized solutions tailored to the specific requirements of each client. Tell us what you need and our team will respond promptly.
      </p>
      <a href="/contact" class="inline-block px-10 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-semibold rounded transition-all duration-200 shadow-lg shadow-orange-600/40 tracking-wide">
        Request a Quote
      </a>
    </div>
  </section>

</Layout>
