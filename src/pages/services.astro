---
import Layout from '../layouts/Layout.astro';
import SiteShell from '../components/SiteShell.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const servicesBackground = `${base}/photos/company-profile/products-services-bg.jpg`;
const quoteMailto = `mailto:${site.contacts.email}?subject=${encodeURIComponent('Quotation Request - COPAK GENERAL TRADING')}`;
const serviceGroupImages: Record<string, string[]> = {
	Laboratory: [
		`${base}/photos/company-profile/labs2.jpg`,
		`${base}/photos/company-profile/labs1.jpg`,
	],
	'Water Treatment': [
		`${base}/photos/new/water treat2.jpeg`,
	],
	Pumps: [
		`${base}/photos/company-profile/pump1.jpg`,
	],
	Valves: [`${base}/photos/company-profile/valves.jpg`],
	Electrical: [`${base}/photos/company-profile/electrical.jpg`],
	Instrumentation: [`${base}/photos/industrial-06.jpg`],
	'Conveyor Belts': [`${base}/photos/company-profile/conveyor-belts.jpg`],
	'Plates, Pipes & Electrowinning': [
		`${base}/photos/company-profile/plates1.jpg`,
		`${base}/photos/company-profile/pipes1.jpg`,
	],
	'Additional Services': [
		`${base}/photos/company-profile/geomembrane1.jpg`,
		`${base}/photos/company-profile/welding.jpg`,
	],
};
---

<Layout title={`Products & Services | ${site.name}`} description="Detailed overview of products and services offered by COPAK GENERAL TRADING.">
	<SiteShell activePath="/services">
		<main class="section services-page">
			<section class="panel intro" style={`--services-bg: url('${servicesBackground}')`}>
				<p class="eyebrow">Products & Services</p>
				<h1>Comprehensive Industrial Solutions</h1>
				<p>
					From laboratory and instrumentation to electrical, pumping systems, and protective equipment, we provide
					integrated support designed for operational continuity and safety.
				</p>
				<div class="intro-actions">
					<a class="quote-button" href={quoteMailto}>Request a Quotation</a>
					<p class="quote-note">Send your requirements directly to our commercial team for pricing and availability.</p>
				</div>
			</section>

			<section class="cards section-gap">
				{site.services.map((group) => {
					const groupImages = serviceGroupImages[group.category] ?? [];

					return (
					<article class="panel group-card">
						{groupImages.length > 0 && (
							<div class={`group-media${groupImages.length > 1 ? ' group-media--duo' : ''}`}>
								{groupImages.map((src, i) => (
									<img src={src} alt={i === 0 ? group.category : `${group.category} ${i + 1}`} loading="lazy" decoding="async" />
								))}
							</div>
						)}
						<div class="group-content">
							<h2>{group.category}</h2>
							<ul>
								{group.items.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</article>
					);
				})}
			</section>
		</main>
	</SiteShell>
</Layout>

<style>
	.services-page {
		padding: 2rem 0;
	}

	.intro {
		position: relative;
		overflow: hidden;
		padding: 1.3rem;
	}

	.intro::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(100deg, rgba(15, 17, 19, 0.9) 0%, rgba(15, 17, 19, 0.72) 48%, rgba(15, 17, 19, 0.88) 100%),
			var(--services-bg) center/cover no-repeat;
		opacity: 0.94;
		z-index: 0;
	}

	.intro > * {
		position: relative;
		z-index: 1;
	}

	.intro h1 {
		font-size: clamp(1.85rem, 3.8vw, 2.8rem);
		margin: 0.4rem 0 0.8rem;
	}

	.intro-actions {
		margin-top: 1.2rem;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.85rem 1rem;
	}

	.quote-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.78rem 1.18rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #d95400, #e77c1f);
		color: #1a1208;
		font-weight: 800;
		font-size: 0.88rem;
		letter-spacing: 0.02em;
		text-decoration: none;
		box-shadow: 0 14px 30px rgba(212, 84, 0, 0.3);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.quote-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 18px 34px rgba(212, 84, 0, 0.38);
	}

	.intro::before {
		animation: introPan 18s ease-in-out infinite alternate;
		transform-origin: center;
	}

	@keyframes introPan {
		0% {
			transform: scale(1.05) translate3d(0, 0, 0);
		}
		100% {
			transform: scale(1.12) translate3d(-2%, -1%, 0);
		}
	}

	.quote-note {
		margin: 0;
		max-width: 34rem;
	}

	.intro p,
	.group-card li {
		color: var(--muted);
	}

	.section-gap {
		padding-top: 1rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.group-card {
		overflow: hidden;
		padding: 0;
	}

	.group-media {
		display: grid;
		grid-template-columns: 1fr;
	}

	.group-media--duo {
		grid-template-columns: 1fr 1fr;
	}

	.group-media img {
		width: 100%;
		height: 170px;
		object-fit: cover;
		display: block;
		filter: saturate(1.05) contrast(1.02);
	}

	.group-content {
		padding: 1rem;
	}

	.group-card h2 {
		font-size: 1.12rem;
		margin-bottom: 0.55rem;
	}

	.group-card ul {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.4rem;
	}

	@media (max-width: 980px) {
		.cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>