---
import Layout from '../layouts/Layout.astro';

const partnerBenefits = [
  {
    icon: '🌐',
    title: 'Advanced Technologies',
    desc: 'Access to cutting-edge industrial technologies through trusted international partnerships.',
  },
  {
    icon: '⚡',
    title: 'Consistent Availability',
    desc: 'Reliable supply chains ensuring product availability when and where you need it most.',
  },
  {
    icon: '🚀',
    title: 'Efficient Delivery',
    desc: 'Streamlined project delivery and logistics backed by our network of established partners.',
  },
  {
    icon: '🔬',
    title: 'Innovative Solutions',
    desc: 'Collaborative approach that drives innovation and continuous improvement in industrial solutions.',
  },
];

const teamQualities = [
  'Highly qualified industrial professionals',
  'Continuously trained on the latest technologies',
  'Specialized in multiple industrial sectors',
  'Committed to excellence and client satisfaction',
  'Available for technical advisory and support',
];

const sectors = [
  { label: 'Mining & Minerals', icon: '⛏️' },
  { label: 'Chemical Processing', icon: '⚗️' },
  { label: 'Manufacturing', icon: '🏭' },
  { label: 'Construction', icon: '🏗️' },
  { label: 'Energy & Power', icon: '⚡' },
  { label: 'Healthcare & Lab', icon: '🧪' },
];
---

<Layout title="Partners & Team — COPAK General Trading" description="COPAK General Trading partners with leading national and international industrial suppliers to deliver quality solutions across the DRC.">

  <!-- PAGE HERO -->
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1569025690938-a00729c9e1f9?auto=format&fit=crop&w=1920&h=900&q=80"
        alt=""
        class="w-full h-full object-cover"
        style="animation: subtle-zoom 27s ease-in-out infinite alternate;"
        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=1920&h=900&q=80';"
      />
      <div class="absolute inset-0 bg-[#0d1b2a]/80"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2a]/86 via-[#1a2838]/62 to-[#0d1b2a]/74"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">
      <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">Our Network</p>
      <h1 class="text-5xl lg:text-6xl font-['Rajdhani'] font-bold text-white mb-6 leading-tight">
        Team &amp; <span class="text-orange-400">Partners</span>
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl leading-relaxed">
        COPAK General Trading's success is driven by the expertise of our team and the strength of our trusted national and international partnerships.
      </p>
    </div>
  </section>

  <!-- OUR TEAM -->
  <section class="py-20 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">The People Behind CGT</p>
        <h2 class="text-3xl font-['Rajdhani'] font-bold text-white mb-6">Driven by Expertise & Dedication</h2>
        <p class="text-gray-300 leading-relaxed mb-5">
          The success of COPAK GENERAL TRADING is driven by the <span class="text-orange-400 font-medium">expertise and dedication of our team</span>. Our professionals are highly qualified and continuously trained to deliver innovative solutions tailored to the specific needs of each client.
        </p>
        <p class="text-gray-300 leading-relaxed mb-8">
          Through strong partnerships, collaboration, and a culture of continuous learning, we consistently strive to exceed client expectations across every project and sector we operate in.
        </p>
        <ul class="space-y-3">
          {teamQualities.map(q => (
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-orange-500 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="text-gray-300 text-sm">{q}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Team visual block -->
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2 bg-gradient-to-br from-orange-950/40 to-[#0f0f0f] border border-orange-900/25 rounded-2xl p-8 text-center">
          <div class="text-5xl mb-3">👥</div>
          <h3 class="text-white font-['Rajdhani'] font-bold text-2xl mb-2">Expert Team</h3>
          <p class="text-gray-500 text-sm">Qualified industrial professionals across electrical, mechanical, instrumentation, and chemical domains.</p>
        </div>
        <div class="bg-[#0f0f0f] border border-gray-800/50 rounded-xl p-6 text-center">
          <div class="text-3xl mb-2">🎯</div>
          <p class="text-orange-400 font-semibold text-sm">Client-Focused</p>
          <p class="text-gray-600 text-xs mt-1">Every solution tailored to you</p>
        </div>
        <div class="bg-[#0f0f0f] border border-gray-800/50 rounded-xl p-6 text-center">
          <div class="text-3xl mb-2">📈</div>
          <p class="text-orange-400 font-semibold text-sm">Always Growing</p>
          <p class="text-gray-600 text-xs mt-1">Continuous training & innovation</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STRATEGIC PARTNERSHIPS -->
  <section class="py-20 bg-[#080808]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-orange-500 text-xs font-semibold tracking-widest uppercase mb-3">Our Network</p>
        <h2 class="text-4xl font-['Rajdhani'] font-bold text-white mb-4">Strategic Partnerships</h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-sm leading-relaxed">
          CGT has established strong relationships with national and international suppliers and industrial partners who share our commitment to excellence, innovation, and reliability.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {partnerBenefits.map(p => (
          <div class="bg-[#0f0f0f] border border-gray-800/50 rounded-xl p-7 hover:border-orange-700/40 transition-all duration-300">
            <div class="text-3xl mb-3">{p.icon}</div>
            <h3 class="text-white font-semibold text-sm mb-2">{p.title}</h3>
            <p class="text-gray-400 text-xs leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>

      <!-- Partnership statement -->
      <div class="relative bg-gradient-to-r from-orange-500/15 via-[#2a4563] to-blue-500/10 border border-orange-500/20 rounded-2xl p-12 text-center overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-orange-500 rounded-l-2xl"></div>
        <div class="absolute bottom-0 right-0 w-1 h-full bg-blue-400 rounded-r-2xl"></div>
        <p class="text-2xl font-['Rajdhani'] font-bold text-white mb-4">
          "We work with partners who share our commitment to<br/>
          <span class="text-orange-300">excellence</span>, <span class="text-blue-300">innovation</span>, and <span class="text-orange-300">reliability</span>."
        </p>
        <p class="text-gray-400 text-sm">— COPAK General Trading Core Partnership Principle</p>
      </div>
    </div>
  </section>

  <!-- SECTORS WE SERVE -->
  <section class="py-20 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center mb-12">
      <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">Industries</p>
      <h2 class="text-4xl font-['Rajdhani'] font-bold text-white">Sectors We Serve</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {sectors.map(s => (
        <div class="bg-[#2d4a63] border border-orange-500/15 rounded-xl p-6 hover:border-orange-500/40 transition-all duration-300 text-center">
          <div class="text-3xl mb-3">{s.icon}</div>
          <p class="text-gray-300 text-xs font-medium leading-tight">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- BECOME A PARTNER CTA -->
  <section class="py-16 bg-[#2a4563] border-t border-orange-500/15">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-['Rajdhani'] font-bold text-white mb-4">Interested in Partnering with CGT?</h2>
      <p class="text-gray-300 mb-8 leading-relaxed">
        We are always open to exploring new partnerships with suppliers, distributors, and industry peers who share our values. Let's build something great together.
      </p>
      <a href="/contact" class="inline-block px-10 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-semibold rounded transition-all duration-200 shadow-lg shadow-orange-600/40 tracking-wide">
        Start a Conversation
      </a>
    </div>
  </section>

</Layout>
