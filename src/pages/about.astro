---
import Layout from '../layouts/Layout.astro';

const commitments = [
  'Adaptability to evolving industry needs',
  'Commitment to excellence in every project',
  'Innovation in industrial solutions',
  'High standards of product quality',
  'Reliable partnerships with clients and suppliers',
];

const values = [
  {
    title: 'Excellence',
    icon: '🏆',
    desc: 'We strive to deliver products and services that consistently meet the highest quality standards across every industry we serve.',
  },
  {
    title: 'Innovation',
    icon: '💡',
    desc: 'We continuously seek innovative solutions to address evolving industrial challenges with smarter, more efficient approaches.',
  },
  {
    title: 'Adaptability',
    icon: '⚙️',
    desc: 'We respond flexibly to the unique requirements of every project, client, and industry sector we operate in.',
  },
  {
    title: 'Commitment',
    icon: '🤝',
    desc: 'We build long-term relationships with our clients by being reliable, responsive, and dedicated partners.',
  },
];
---

<Layout title="About COPAK General Trading" description="Founded in 2023, COPAK General Trading (CGT) is a Congolese industrial solutions company with expertise in electrical, mechanical, and industrial instrumentation systems.">

  <!-- PAGE HERO -->
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1487958449943-2429e8be8625?auto=format&fit=crop&w=1920&h=900&q=80"
        alt=""
        class="w-full h-full object-cover"
        style="animation: subtle-zoom 26s ease-in-out infinite alternate;"
        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=1920&h=900&q=80';"
      />
      <div class="absolute inset-0 bg-[#0d1b2a]/78"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2a]/86 via-[#1a2838]/58 to-[#0d1b2a]/72"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">
      <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">Who We Are</p>
      <h1 class="text-5xl lg:text-6xl font-['Rajdhani'] font-bold text-white mb-6 max-w-2xl leading-tight">
        About COPAK<br/><span class="text-orange-500">General Trading</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl leading-relaxed">
        A Congolese company built on expertise, driven by commitment, and trusted across the most demanding industries in the Democratic Republic of Congo.
      </p>
    </div>
  </section>

  <!-- COMPANY OVERVIEW -->
  <section class="py-20 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">Company Overview</p>
        <h2 class="text-3xl font-['Rajdhani'] font-bold text-white mb-6">Complete Industrial Solutions, Tailored to You</h2>
        <p class="text-gray-400 leading-relaxed mb-5">
          COPAK GENERAL TRADING (CGT) is recognized for its expertise in delivering <span class="text-orange-400 font-medium">complete industrial solutions</span> — from the supply of industrial equipment to installation, maintenance, and technical support.
        </p>
        <p class="text-gray-400 leading-relaxed mb-5">
          Founded in <span class="text-white font-semibold">2023</span>, CGT operates from Lubumbashi, Haut Katanga Province, serving businesses across multiple sectors in the DRC with reliable products and customized service.
        </p>
        <p class="text-gray-400 leading-relaxed">
          With a team of experienced professionals, we provide customized solutions tailored to the specific requirements of each client, ensuring quality, reliability, and operational excellence.
        </p>
      </div>

      <!-- Registration info box -->
      <div class="bg-[#2a4563] border border-orange-500/25 rounded-2xl p-8">
        <h3 class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-6">Business Registration</h3>
        <ul class="space-y-4">
          {[
            { label: 'RCCM', value: 'CD/LSH/RCCM/24-B-00695' },
            { label: 'ID NAT', value: '05-S9502-N58278L' },
            { label: 'Tax Number', value: 'A2408513F' },
            { label: 'ARSP', value: '6209253671' },
            { label: 'Founded', value: '2023' },
            { label: 'Location', value: 'Lubumbashi, Haut Katanga, DRC' },
          ].map(item => (
            <li class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 border-b border-gray-700/40 pb-4 last:border-0 last:pb-0">
              <span class="text-gray-400 text-xs font-semibold tracking-wider uppercase w-28 shrink-0">{item.label}</span>
              <span class="text-white text-sm font-mono">{item.value}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- VISION & MISSION -->
  <section class="py-20 bg-[#1a2635]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">Direction</p>
        <h2 class="text-4xl font-['Rajdhani'] font-bold text-white">Vision & Mission</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Vision -->
        <div class="relative bg-[#2d4a63] border border-orange-500/25 rounded-2xl p-10 overflow-hidden">
          <div class="absolute top-0 left-0 w-1 h-full bg-orange-500 rounded-l-2xl"></div>
          <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-4">Vision</p>
          <h3 class="text-2xl font-['Rajdhani'] font-bold text-white mb-4">DRC's Leading Industrial Provider</h3>
          <p class="text-gray-400 leading-relaxed">
            COPAK GENERAL TRADING aims to become the <span class="text-orange-300 font-medium">leading provider of industrial solutions in the Democratic Republic of Congo</span> — the preferred partner for companies across multiple sectors, delivering high-quality products and services that meet specific industry needs.
          </p>
        </div>

        <!-- Mission -->
        <div class="relative bg-[#2d4a63] border border-blue-500/25 rounded-2xl p-10 overflow-hidden">
          <div class="absolute top-0 left-0 w-1 h-full bg-blue-400 rounded-l-2xl"></div>
          <p class="text-blue-300 text-xs font-semibold tracking-widest uppercase mb-4">Mission</p>
          <h3 class="text-2xl font-['Rajdhani'] font-bold text-white mb-4">Comprehensive, Innovative Solutions</h3>
          <p class="text-gray-300 leading-relaxed mb-5">
            Our mission is to provide comprehensive and innovative industrial solutions tailored to the needs of our clients, going beyond supply to deliver:
          </p>
          <ul class="space-y-2">
            {[
              'High-quality industrial products',
              'Exceptional after-sales support',
              'Long-term trust-based relationships',
              'Technical expertise with personalized service',
            ].map(item => (
              <li class="flex items-start gap-2 text-sm text-gray-300">
                <span class="text-blue-500 mt-1 shrink-0">&#10003;</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR VALUES -->
  <section class="py-20 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center mb-14">
        <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">What Drives Us</p>
      <h2 class="text-4xl font-['Rajdhani'] font-bold text-white">Our Core Values</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map(v => (
        <div class="bg-[#2d4a63] border border-orange-500/15 rounded-xl p-7 hover:border-orange-500/40 transition-all duration-300 group text-center">
          <div class="text-4xl mb-4">{v.icon}</div>
          <h3 class="text-white font-['Rajdhani'] font-bold text-xl mb-3">{v.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{v.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- COMMITMENTS -->
  <section class="py-20 bg-[#1a2635]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <p class="text-orange-400 text-xs font-semibold tracking-widest uppercase mb-3">How We Operate</p>
          <h2 class="text-3xl font-['Rajdhani'] font-bold text-white mb-5">Our Commitments</h2>
          <p class="text-gray-300 leading-relaxed mb-8">
            Since its establishment in 2023, COPAK GENERAL TRADING has been committed to delivering tailored solutions and exceptional service. Our operations are built on principles that ensure we remain a trusted partner.
          </p>
          <ul class="space-y-4">
            {commitments.map(c => (
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 rounded-full bg-orange-500 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white font-bold" fill="currentColor" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-gray-200 text-sm">{c}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-gradient-to-br from-orange-500/15 to-[#1a2635] border border-orange-500/25 rounded-2xl p-10 text-center">
          <div class="text-6xl font-['Rajdhani'] font-bold text-orange-400 mb-2">CGT</div>
          <p class="text-white font-semibold text-lg mb-1">COPAK General Trading</p>
          <p class="text-gray-400 text-sm mb-8">Lubumbashi · Haut Katanga · DRC</p>
          <div class="h-px bg-orange-500/30 mb-8"></div>
          <p class="text-gray-300 text-sm leading-relaxed italic">
            "These commitments enable CGT to maintain its reputation as a trusted partner in industrial solutions within the Democratic Republic of Congo."
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
