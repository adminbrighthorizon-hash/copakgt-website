---
const serviceGroups = [
  {
    category: "Pumps & Valves",
    points: ["Centrifugal and slurry pumps", "Control and isolation valves", "Mechanical seal support"],
  },
  {
    category: "Electrical & Instrumentation",
    points: ["Switchgear and cable systems", "Field instrumentation and calibration", "Control panel integration"],
  },
  {
    category: "PPE & Laboratory Equipment",
    points: ["Certified safety gear for industrial teams", "Sampling and testing tools", "Laboratory consumables"],
  },
  {
    category: "Specialized Services",
    points: ["Geomembrane installation and repair", "Industrial welding interventions", "Crusher maintenance services"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Services | COPAK GENERAL TRADING</title>
    <meta name="description" content="Industrial services and products by COPAK GENERAL TRADING." />
    <style>
      :root { --bg:#121212; --surface:#1a1a1a; --line:#333; --text:#eef0f2; --muted:#c4c8cc; --accent:#f26522; }
      * { box-sizing:border-box; }
      body { margin:0; background:var(--bg); color:var(--text); font-family:Roboto, "Segoe UI", Arial, sans-serif; }
      .wrap { width:min(1100px, 92%); margin:0 auto; }
      .hero { padding:2rem 0; }
      .hero-card { border:1px solid var(--line); border-radius:16px; padding:2rem; background:linear-gradient(160deg, #1a1a1a, #232323); }
      h1,h2,h3 { margin:0 0 .75rem; font-family:Montserrat, Roboto, sans-serif; }
      .eyebrow { color:#ffc49f; text-transform:uppercase; letter-spacing:.12em; font-size:.76rem; }
      .desc { color:var(--muted); margin:0; max-width:72ch; }
      .grid { padding:0 0 2.4rem; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:1rem; }
      .card { border:1px solid var(--line); border-radius:14px; padding:1rem; background:var(--surface); transition:border-color .2s ease, transform .2s ease; }
      .card:hover { border-color:rgba(242,101,34,.7); transform:translateY(-3px); }
      ul { margin:.5rem 0 0; padding-left:1.1rem; color:var(--muted); }
      a { color:#fff; text-decoration:none; }
      .top { padding:1rem 0; border-bottom:1px solid var(--line); }
      .top a { color:var(--muted); }
      .contact { margin:0 0 2.4rem; }
      .contact h2 { margin-bottom:.35rem; }
      .contact p { margin:.35rem 0; color:var(--muted); }
      @media (max-width:840px){ .grid{grid-template-columns:1fr;} }
    </style>
  </head>
  <body>
    <div class="top">
      <div class="wrap"><a href="{Astro.base}">← Back to Home</a></div>
    </div>
    <main class="wrap">
      <section class="hero">
        <article class="hero-card">
          <p class="eyebrow">CGT Portfolio</p>
          <h1>Industrial Products and Specialized Services</h1>
          <p class="desc">
            End-to-end support for procurement, maintenance, and field operations in mining and heavy industry.
          </p>
        </article>
      </section>
      <section class="grid">
        {serviceGroups.map((group) => (
          <article class="card">
            <h3>{group.category}</h3>
            <ul>
              {group.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </section>
      <section class="contact">
        <article class="card">
          <h2>Contact</h2>
          <p>Av. 33 Tony Mwana, Q/ Golf Karavia Plateaux 3</p>
          <p>C/ Annexe, Lubumbashi, Haut-Katanga, DRC</p>
          <p>DRC Phone: <a href="tel:+243897980803">+243 89 798 0803</a></p>
          <p>South Africa Phone: <a href="tel:+27677584446">+27 67 758 4446</a></p>
          <p>Email: <a href="mailto:info@copakgt.com">info@copakgt.com</a></p>
        </article>
      </section>
    </main>
  </body>
</html>