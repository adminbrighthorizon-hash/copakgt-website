---
const highlights = [
  "Fast-response sourcing for critical industrial components",
  "Field coordination with engineering and procurement teams",
  "Quality-first execution in demanding operating conditions",
  "Long-term reliability for mining and process operations",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Impact | COPAK GENERAL TRADING</title>
    <meta name="description" content="Operational impact delivered by COPAK GENERAL TRADING." />
    <style>
      :root { --bg:#121212; --surface:#1a1a1a; --line:#333; --text:#eef0f2; --muted:#c4c8cc; --accent:#f26522; }
      * { box-sizing:border-box; }
      body { margin:0; background:var(--bg); color:var(--text); font-family:Roboto, "Segoe UI", Arial, sans-serif; }
      .wrap { width:min(980px,92%); margin:0 auto; }
      .top { padding:1rem 0; border-bottom:1px solid var(--line); }
      .top a { color:var(--muted); text-decoration:none; }
      h1,h2 { margin:0 0 .8rem; font-family:Montserrat, Roboto, sans-serif; }
      .hero { padding:2rem 0 1rem; }
      .hero-card { border:1px solid var(--line); border-radius:16px; padding:2rem; background:linear-gradient(160deg, #1a1a1a, #242424); }
      .eyebrow { color:#ffc49f; text-transform:uppercase; letter-spacing:.12em; font-size:.76rem; margin:0 0 .75rem; }
      .desc { color:var(--muted); margin:0; max-width:68ch; }
      .list { padding:0 0 1.2rem; display:grid; gap:.8rem; }
      .item { border:1px solid var(--line); border-left:3px solid var(--accent); border-radius:12px; background:var(--surface); padding:.95rem; color:var(--muted); }
      .card { border:1px solid var(--line); border-radius:14px; padding:1rem; background:var(--surface); }
      .contact { margin:0 0 2.2rem; }
      .contact h2 { margin-bottom:.35rem; }
      .contact p { margin:.35rem 0; color:var(--muted); }
    </style>
  </head>
  <body>
    <div class="top">
      <div class="wrap"><a href="{Astro.base}">← Back to Home</a></div>
    </div>
    <main class="wrap">
      <section class="hero">
        <article class="hero-card">
          <p class="eyebrow">Operational Impact</p>
          <h1>Reliable execution where uptime matters most.</h1>
          <p class="desc">
            COPAK GENERAL TRADING supports heavy industry with dependable delivery, technical rigor, and adaptive service under field conditions.
          </p>
        </article>
      </section>
      <section class="list">
        {highlights.map((highlight) => <article class="item">{highlight}</article>)}
      </section>
      <section class="contact">
        <article class="card">
          <h2>Contact</h2>
          <p>Av. 33 Tony Mwana, Q/ Golf Karavia Plateaux 3</p>
          <p>C/ Annexe, Lubumbashi, Haut-Katanga, DRC</p>
          <p>DRC Phone: <a href="tel:+243897980803">+243 89 798 0803</a></p>
          <p>South Africa Phone: <a href="tel:+27677584446">+27 67 758 4446</a></p>
          <p>Email: <a href="mailto:info@copakgt.com">info@copakgt.com</a></p>
        </article>
      </section>
    </main>
  </body>
</html>